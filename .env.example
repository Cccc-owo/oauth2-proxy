# Required security secret
# Must be a high-entropy secret with at least 32 characters
STATE_SECRET=replace_with_a_long_random_state_signing_secret

# Provider Control (optional)
# Comma-separated list of enabled providers, or 'all' to enable all configured providers
# If not set, all configured providers are enabled
# ENABLED_PROVIDERS=gmail,outlook,icloud
# ENABLED_PROVIDERS=gmail
# ENABLED_PROVIDERS=all

# Gmail OAuth2 Configuration
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8080/oauth2/callback

# Outlook OAuth2 Configuration (optional)
OUTLOOK_CLIENT_ID=your_outlook_client_id_here
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret_here
OUTLOOK_REDIRECT_URI=http://localhost:8080/oauth2/callback

# iCloud Mail OAuth2 Configuration (optional)
# Must be HTTPS in production and cannot be localhost
# ICLOUD_CLIENT_ID=your_icloud_client_id_here
# ICLOUD_REDIRECT_URI=https://yourdomain.com/oauth2/callback
# APPLE_TEAM_ID=your_apple_team_id_here
# APPLE_KEY_ID=your_apple_key_id_here
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Security Configuration (optional)
# Comma-separated list of allowed browser origins. Non-browser clients can omit Origin.
ALLOWED_ORIGINS=https://yourdomain.com

# Optional Bearer protection for /api/token and /api/refresh
# When enabled, callers must send Authorization: Bearer <token>
# You can configure one token or multiple comma-separated tokens for rotation
# ACCESS_TOKEN_AUTH_ENABLED=true
# ACCESS_TOKEN_AUTH_TOKENS=replace_with_a_long_random_secret,replace_with_next_secret

# Only enable this when your deployment platform overwrites x-forwarded-for/x-real-ip
# and you trust that proxy chain.
# TRUST_PROXY_HEADERS=true

# Server Port (for local development only)
PORT=3001
